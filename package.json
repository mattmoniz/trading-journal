{
  "name": "trading-journal",
  "version": "1.0.0",
  "description": "Professional Trading Journal with PostgreSQL",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "vite",
    "build": "vite build",
    "db:setup": "node server/scripts/setupDb.js",
    "db:seed": "node server/scripts/seedDb.js",
    "start:all": "./start.sh",
    "stop:all": "./stop.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "plotly.js": "^3.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-pivottable": "^0.11.1",
    "react-plotly.js": "^2.6.0",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "vite": "^5.0.8"
  }
}
